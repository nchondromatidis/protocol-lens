{
  "name": "@defi-notes/evm-lens-ui",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./components/*": "./src/components/*.tsx",
    "./types/*": "./src/types/*.ts",
    "./styles/*.css": "./src/styles/*.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "check:types": "tsc --build --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:playground": "vite --config vite.config.ts",
    "build:lib": "vite build --mode lib",
    "build:lib:watch": "vite build --watch --mode lib",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@defi-notes/evm-lens": "workspace:*",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@replit/codemirror-lang-solidity": "^6.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "@uiw/react-codemirror": "^4.25.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react-resizable-panels": "^4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@defi-notes/config": "workspace:*",
    "@defi-notes/protocols": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "shadcn": "^4.1.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0",
    "viem": "2.37.13",
    "vite": "^7.3.2",
    "vite-multiple-assets": "^2.2.6",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^4.0.1",
    "vitest": "^4.1.2"
  }
}
