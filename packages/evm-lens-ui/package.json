{
  "name": "@defi-notes/evm-lens-ui",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*.css": "./dist/*.css",
    "./styles/*.css": "./dist/styles/*.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "check:types:web": "tsc -p tsconfig.web.json --noEmit",
    "check:types:node": "tsc -p tsconfig.node.json --noEmit",
    "check:types": "pnpm run check:types:web && pnpm run check:types:node",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:playground": "vite --config vite.config.ts",
    "build:lib": "vite build --mode lib",
    "build:lib:watch": "vite build --watch --mode lib",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.12",
    "@defi-notes/evm-lens": "workspace:*",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@replit/codemirror-lang-solidity": "^6.0.2",
    "@tailwindcss/vite": "^4.1.18",
    "@uiw/react-codemirror": "^4.25.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react-resizable-panels": "^4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@defi-notes/config": "workspace:*",
    "@defi-notes/protocols": "workspace:*",
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.2.0",
    "prettier": "3.8.1",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "viem": "2.37.9",
    "vite": "^6.4.0",
    "vite-multiple-assets": "^2.2.6",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18",
    "zod-validation-error": "3.5.3"
  }
}
