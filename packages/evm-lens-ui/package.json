{
  "name": "@defi-notes/evm-lens-ui",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./components/*": "./src/components/*.tsx",
    "./types/*": "./src/types/*.ts",
    "./styles/*.css": "./src/styles/*.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "check:types": "tsc --build --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:playground": "vite --config vite.config.ts",
    "build:lib": "vite build --mode lib",
    "build:lib:watch": "vite build --watch --mode lib",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "dependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@defi-notes/evm-lens": "workspace:*",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@replit/codemirror-lang-solidity": "^6.0.2",
    "@tailwindcss/vite": "catalog:",
    "@uiw/react-codemirror": "^4.25.9",
    "clsx": "catalog:",
    "react-resizable-panels": "^4",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@defi-notes/config": "workspace:*",
    "@defi-notes/workflows": "workspace:*",
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "viem": "catalog:",
    "vite": "catalog:",
    "vite-multiple-assets": "^2.2.6",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^4.0.1",
    "vitest": "catalog:"
  }
}
