{
  "name": "evm-lens-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/index.css"
  },
  "scripts": {
    "check:types": "tsc -p tsconfig.web.json --noEmit",
    "sync:protocols:copy": "rm -rf public && mkdir -p public/protocols && cp -r ../protocols/artifacts public/protocols/ && cp -r ../protocols/contracts public/protocols/",
    "sync:protocols:symlink": "rm -rf public && mkdir -p public && ln -sfn ../../protocols/artifacts  public/artifacts && ln -sfn ../../protocols/contracts public/contracts",
    "predev:playground": "pnpm run sync:protocols:symlink",
    "dev:playground": "vite",
    "prebuild": "pnpm run sync:protocols:copy",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/theme-one-dark": "^6.1.3",
    "@defi-notes/evm-lens": "workspace:*",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@replit/codemirror-lang-solidity": "^6.0.2",
    "@tailwindcss/vite": "^4.1.18",
    "@uiw/react-codemirror": "^4.25.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.5.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@defi-notes/config": "workspace:*",
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.2.0",
    "prettier": "3.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "zod-validation-error": "3.5.3"
  }
}
