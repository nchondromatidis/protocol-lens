{
  "name": "@defi-notes/evm-lens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "React component for visualising tevm transactions",
  "scripts": {
    "check:types": "tsc --noEmit",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:contracts:build:clean": "rm -rf test/_setup/artifacts && rm -rf cache",
    "test:contracts:build": "pnpm exec hardhat build --force",
    "test:contracts:build:debug": "DEBUG=hardhat:* pnpm exec hardhat build --force --show-stack-traces",
    "test": "pnpm run check:types && pnpm run test:contracts:build && vitest --watch=false",
    "test:no-build": "vitest --watch=false"
  },
  "dependencies": {
    "tevm": "^1.0.0-next.149",
    "viem": "^2.38.6"
  },
  "devDependencies": {
    "@defi-notes/config": "workspace:*",
    "@defi-notes/hardhat-evm-lens": "workspace:*",
    "@defi-notes/protocols": "workspace:*",
    "@eslint/js": "^9.36.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "hardhat": "^3.0.14",
    "prettier": "3.7.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4"
  }
}
