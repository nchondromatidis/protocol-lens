    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@defi-notes/protocols": "*",
    "tevm": "^1.0.0-next.147"
  },
  "devDependencies": {
    "@defi-notes/config": "*",
    "@eslint/js": "^9.36.0",
    "abitype": "^1.1.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "prettier": "3.6.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4"
  }
}
