{
  "name": "@defi-notes/tevm-lens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "React component for visualising tevm transactions",
  "scripts": {
    "check:types": "tsc --noEmit",
    "dev": "vite --config test/playground/vite.config.ts",
