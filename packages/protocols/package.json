{
  "name": "@defi-notes/protocols",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "hardhat:clear": "hardhat clean",
    "hardhat:build": "hardhat build --show-stack-traces",
    "wagmi:generate": "wagmi generate",
    "hardhat:tasks:source-maps": "tsx tasks/inject-sourcemaps.ts",
    "hardhat:tasks:filter-contracts": "tsx tasks/filter-contracts.ts",
    "build": "npm run hardhat:clear && npm run hardhat:tasks:filter-contracts && npm run hardhat:build && npm run wagmi:generate && npm run hardhat:tasks:source-maps"
  },
  "devDependencies": {
    "@defi-notes/config": "*",
    "@types/node": "^24.5.2",
    "@wagmi/cli": "^2.5.1",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.0.6",
    "minimatch": "^10.0.3",
    "tsx": "^4.20.5",
    "typescript": "~5.9.2",
    "viem": "^2.37.8"
  }
}
